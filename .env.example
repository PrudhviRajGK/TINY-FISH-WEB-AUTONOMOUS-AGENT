# Fragment Video Generator - Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (True/False)
DEBUG=True

# Server host and port
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000

# ============================================
# API KEYS (REQUIRED)
# ============================================

# OpenAI API Key - REQUIRED for script generation and DALL-E image generation
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# TinyFish API Key - REQUIRED. The automation pipeline cannot run without it.
# Get it from: https://tinyfish.ai/api-keys
TINYFISH_API_KEY=your_tinyfish_api_key_here

# TinyFish Web Agent API Base URL
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1

# ============================================
# STOCK VIDEO API KEYS (OPTIONAL)
# Enables real motion clips in generated videos.
# Without these, the pipeline falls back to AI images with Ken Burns effect.
# ============================================

# Pexels API Key - free tier available at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key - free tier available at https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# ============================================
# ELEVENLABS TTS (PRIMARY NARRATION ENGINE)
# ============================================

# ElevenLabs API Key - get it from https://elevenlabs.io
# If not set, the system falls back to Kokoro TTS.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ============================================
# SOCIAL MEDIA API KEYS (OPTIONAL)
# ============================================

# YouTube Data API v3
# Get credentials from: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_ACCESS_TOKEN=your_youtube_access_token_he

# ============================================
# VIDEO GENERATION SETTINGS
# ============================================

# Default video duration in seconds
DEFAULT_VIDEO_DURATION=60

# Default frames per second for video output
DEFAULT_VIDEO_FPS=24

# Default chunk size for subtitle splitting
DEFAULT_CHUNK_SIZE=10

# ============================================
# DALL-E IMAGE GENERATION SETTINGS
# ============================================

# DALL-E model to use (dall-e-2, dall-e-3)
DALLE_MODEL=dall-e-3

# Image size (1024x1024, 1792x1024, 1024x1792 for dall-e-3)
DALLE_SIZE=1024x1024

# Image quality (standard, hd)
DALLE_QUALITY=standard

# Delay between DALL-E API calls (seconds)
IMAGE_GEN_DELAY=2.0

# ============================================
# TTS (TEXT-TO-SPEECH) SETTINGS
# ============================================

# TTS language code (b for English)
TTS_LANG_CODE=b

# ============================================
# FILE UPLOAD SETTINGS
# ============================================

# Maximum upload size in bytes (50MB default)
MAX_UPLOAD_SIZE=52428800

# ============================================
# BACKGROUND TASK SETTINGS
# ============================================

# Task timeout in seconds (10 minutes default)
TASK_TIMEOUT=600

# ============================================
# LOGGING SETTINGS
# ============================================

# Log file name
LOG_FILE=app.log

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# NOTES
# ============================================

# 1. Paths are automatically configured based on the project structure
# 2. All resource directories (images, audio, videos, subtitles) are created automatically
# 3. Font and intro image paths are resolved from resources/font/font.ttf and resources/intro/intro.jpg
# 4. Make sure to create a .env file from this template and fill in your actual values
# 5. Never commit your .env file to version control!