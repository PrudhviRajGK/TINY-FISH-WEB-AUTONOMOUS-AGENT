      "speed": 1.0,
      "pitch": 1.0,
      "emotion": "informative"
    },
    {
      "timestamp": "00:13",
      "text": "\u092f\u0939 \u092e\u0949\u0921\u0932 \u091a\u093f\u0915\u093f\u0924\u094d\u0938\u093e, \u0915\u093e\u0928\u0942\u0928, \u0914\u0930 \u0915\u094b\u0921\u093f\u0902\u0917 \u092e\u0947\u0902 \u092e\u093e\u0928\u0935 \u0935\u093f\u0936\u0947\u0937\u091c\u094d\u091e\u094b\u0902 \u0915\u094b \u092a\u0940\u091b\u0947 \u091b\u094b\u0921\u093c\u0924\u0947 \u0939\u0941\u090f 90 \u092a\u094d\u0930\u0924\u093f\u0936\u0924 \u0938\u094d\u0915\u094b\u0930 \u0915\u0930\u0924\u093e \u0939\u0948\u0964",
